{
  "manifest_version": 3,
  "name": "Homestead Overlay Planner",
  "version": "1.0.0",
  "description": "Draw and save homestead planning overlays on top of Google Maps.",
  "icons": {
    "16": "store-assets/icon-16.png",
    "32": "store-assets/icon-32.png",
    "48": "store-assets/icon-48.png",
    "128": "store-assets/icon-128.png"
  },
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "https://www.google.com/maps/*",
    "https://www.google.ca/maps/*",
    "https://maps.google.com/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_title": "Homestead Overlay Planner",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "store-assets/icon-16.png",
      "32": "store-assets/icon-32.png"
    }
  }
}
